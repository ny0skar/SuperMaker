# SuperMaker Server Configuration
# ================================

# Database
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/supermaker_db"

# JWT
JWT_SECRET="your-jwt-secret-here"
JWT_REFRESH_SECRET="your-jwt-refresh-secret-here"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# Server
PORT=4000
NODE_ENV="development"
